<odoo>
  <data>
   <record id="product_internal_ref_purchase" model="ir.ui.view">
        <field name="name">purchase.order.category</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">

            <xpath expr="//sheet/notebook/page/field[@name='order_line']/tree/field[@name='product_id']" position="after">
                <field name="internal_ref" force_save="1"/>
            </xpath>

        </field>
    </record>


        <record id="vendor_product_internal_ref" model="ir.ui.view">
        <field name="name">account.move.category</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='invoice_line_ids']/tree/field[@name='product_id']" position="after">
                <field name="internal_ref" attrs="{'invisible': [('parent.type', 'in', ('out_invoice', 'out_refund', 'out_receipt'))]}" force_save="1"/>
            </xpath>
             <xpath expr="//field[@name='line_ids']/tree/field[@name='product_id']" position="after">
                <field name="internal_ref" invisible="1" force_save="1"/>
            </xpath>
        </field>
        </record>
  </data>
</odoo>